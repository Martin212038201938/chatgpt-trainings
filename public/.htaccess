# ============================================
# .htaccess für chatgpt-trainings.de
# DOMAIN-MIGRATION ZU copilotenschule.de
# ============================================
# Alle URLs dieser Domain werden dauerhaft (301) auf die
# Startseite von copilotenschule.de weitergeleitet.
#
# Ausgenommen sind:
#   - robots.txt  → muss für Crawler erreichbar bleiben,
#                   damit sie die 301-Redirects überhaupt verarbeiten
#   - IndexNow Key-Dateien (32-Hex .txt im Root)
#   - favicon.ico → vermeidet unnötige Browser-Fehler
#
# Hinweis: React-SPA, index.html und sitemap.xml werden
# bewusst nicht mehr ausgeliefert. Alles fließt in den 301.
# ============================================

RewriteEngine On
RewriteBase /

# ============================================
# HTTPS erzwingen (Fallback, falls Server-Setting ausfällt)
# ============================================
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteCond %{HTTPS} off
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L,NE]

# ============================================
# AUSNAHMEN (dürfen NICHT umgeleitet werden)
# ============================================

# robots.txt direkt ausliefern
RewriteRule ^robots\.txt$ - [L,NC]

# IndexNow Key-Dateien im Root (32-char hex .txt)
RewriteRule ^[0-9a-f]{32}\.txt$ - [L,NC]

# favicon
RewriteRule ^favicon\.ico$ - [L,NC]

# ============================================
# GLOBALER 301-REDIRECT AUF copilotenschule.de
# ============================================
# Alle übrigen Anfragen (egal ob Homepage, /wissen/*, /ueber-uns,
# Sitemap, Assets oder 404-Pfade) werden permanent zur
# Startseite der copilotenschule.de umgeleitet.
#
# QSD = Query String Discard (verhindert, dass UTM-Parameter etc.
#       an die Zielseite mitgeschleift werden → saubere Ziel-URL).
# R=301 = dauerhafte Weiterleitung (SEO: Signal-Transfer).
# L     = Regel als letzte behandeln.
# ============================================

RewriteRule ^ https://copilotenschule.de/ [R=301,L,QSD]

# ============================================
# SICHERHEIT
# ============================================
Options -Indexes

# Sicherheits-Header (falls doch mal Content direkt ausgeliefert wird)
<IfModule mod_headers.c>
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-Content-Type-Options "nosniff"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
